generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UploadStatus {
  NEW
  UPLOADING
  MERGING
  COMPLETED
  FAILED
}

model Upload {
  id             String @id @default(uuid())
  fileHash       String @unique
  fileName       String
  fileSize       BigInt
  totalChunks    Int
  uploadedChunks Int    @default(0)

  status UploadStatus @default(NEW)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("uploads")
}
